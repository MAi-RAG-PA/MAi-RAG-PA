# ============================================================================
# MAi-RAG-PA .gitignore - Security-First Configuration
# ============================================================================

# ============================================================================
# SECURITY & SECRETS (HIGHEST PRIORITY)
# ============================================================================
.encryption_key
*.pem
*.key
*.p12
*.pfx
*.jks
*-secret.json
*-credentials.json
.env
.env.local
.env.*.local
.env.production
.env.development
.env.staging

# ============================================================================
# RUNTIME DATA & DATABASES
# ============================================================================
/memory/
storage/
*.db
*.db-journal
*.db-shm
*.db-wal
*.sqlite
*.sqlite3
raft_state.json
.qdrant-initialized

# ============================================================================
# ML MODELS (Downloaded by install.sh)
# ============================================================================
models/*.bin
models/*.gguf
models/*.safetensors
models/*.onnx
models/*.h5
models/*.ot
models/all-MiniLM-L6-v2/
models/vosk-model-*/
!models/.gitkeep

# ============================================================================
# USER-GENERATED CONTENT
# ============================================================================
workspace/
chunks_output/
dev-sandbox/MAi-RAG-DEV/

# ============================================================================
# PYTHON
# ============================================================================
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
venv/
env/
ENV/
.venv
pip-log.txt
pip-delete-this-directory.txt
.pytest_cache/
.coverage
htmlcov/
.tox/
nosetests.xml
coverage.xml
*.cover
*.egg-info/

# ============================================================================
# NODE.JS & FRONTEND
# ============================================================================
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ============================================================================
# BUILD OUTPUTS
# ============================================================================
dist/
build/
*.egg-info/

# ============================================================================
# LOGS & TEMPORARY FILES
# ============================================================================
*.log
logs/
watchdog.log
qdrant.log
*.tmp
*.temp
.cache/
.metadata_cache/

# ============================================================================
# IDE & EDITOR FILES
# ============================================================================
.vscode/
.idea/
*.swp
*.swo
*~
*.sublime-project
*.sublime-workspace

# ============================================================================
# OS FILES
# ============================================================================
.DS_Store
.AppleDouble
.Icon?
Thumbs.db
ehthumbs.db
Desktop.ini

# ============================================================================
# QDRANT BINARY (Users download their own)
# ============================================================================
qdrant
qdrant.exe

# ============================================================================
# BACKUP FILES
# ============================================================================
*.bak
*.backup
*.old
*.orig

# ============================================================================
# LOCAL UTILITIES & SCRIPTS (Not part of release)
# ============================================================================
sync-to-release.sh
MAi-RAG-PA-ONLY-clean-for-release.sh
MAi-RAG-to-MAi-RAG-PA.txt
recovery.sh

# ============================================================================
# TESTING & DEVELOPMENT
# ============================================================================
tests/
scripts/
*.test.js
*.spec.js

# ============================================================================
# FILES TO EXPLICITLY INCLUDE (Override ignores if needed)
# ============================================================================
!requirements.txt
!requirements-dev.txt
!install.sh
!start.sh
!stop.sh
!first_launch.py
!watchdog.py
!launch.sh
!launch.bat
!launch.vbs
!update.sh
!update-mac.command
