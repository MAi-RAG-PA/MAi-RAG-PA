# ============================================================================
# MAi-RAG-PA .gitignore
# ============================================================================

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
venv/
env/
ENV/
.venv
pip-log.txt
pip-delete-this-directory.txt

# Node.js
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Build outputs
frontend/dist/
frontend/build/
*.egg-info/
dist/
build/

# Databases and storage
memory/*.db
memory/*.db-journal
storage/
*.sqlite
*.sqlite3

# Logs
*.log
logs/
watchdog.log
qdrant.log

# IDE and editor files
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# Environment variables
.env
.env.local
.env.*.local

# Qdrant binary (users will download their own)
qdrant
qdrant.exe

# Temporary files
*.tmp
*.temp
.cache/
.metadata_cache/

# Testing and development
.pytest_cache/
.coverage
htmlcov/
.tox/
nosetests.xml
coverage.xml
*.cover

# OS files
.DS_Store
.AppleDouble
.Icon?
Thumbs.db
ehthumbs.db
Desktop.ini

# Model files (too large for GitHub)
models/*.bin
models/*.gguf
models/*.safetensors
!models/.gitkeep

# Workspace (user-generated content)
workspace/

# Dev sandbox contents (but keep the directory structure)
dev-sandbox/MAi-RAG-DEV/
!dev-sandbox/.gitkeep

# Chunked documents
chunks_output/

# Backup files
*.bak
*.backup
*.old

# Encryption keys
.encryption_key

# ============================================================================
# Files to INCLUDE (override ignores if needed)
# ============================================================================
!requirements.txt
!install.sh
!start.sh
!stop.sh
!first_launch.py
!watchdog.py
!ARCHITECTURE.md
!dev-sandbox/.gitkeep.qdrant-initialized
